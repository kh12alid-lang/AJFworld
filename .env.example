# ============================================
# AJworld E-commerce Environment Configuration
# ============================================

# App Configuration
VITE_APP_NAME=AJworld
VITE_APP_URL=https://ajworld.ae
VITE_APP_DESCRIPTION="AJworld - وجهتك المثالية للتسوق الإلكتروني في الإمارات"

# API Configuration
VITE_API_URL=https://api.ajworld.ae/v1
VITE_API_TIMEOUT=30000

# Authentication
VITE_JWT_SECRET=your-jwt-secret-key-here
VITE_TOKEN_EXPIRY=7d

# Payment Gateways
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
VITE_STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
VITE_TABBY_PUBLIC_KEY=your_tabby_public_key
VITE_TAMARA_PUBLIC_KEY=your_tamara_public_key

# Social Login
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_FACEBOOK_APP_ID=your-facebook-app-id
VITE_APPLE_CLIENT_ID=your-apple-client-id

# Firebase Configuration (for Push Notifications)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=ajworld-ae.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ajworld-ae
VITE_FIREBASE_STORAGE_BUCKET=ajworld-ae.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_VAPID_KEY=your-firebase-vapid-key

# Google Maps (for GPS Tracking)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Analytics
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_FACEBOOK_PIXEL_ID=1234567890

# reCAPTCHA
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# AWS S3 (for file uploads)
VITE_AWS_S3_BUCKET=ajworld-uploads
VITE_AWS_S3_REGION=me-south-1
VITE_AWS_ACCESS_KEY_ID=your-aws-access-key
VITE_AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Email Service
VITE_SENDGRID_API_KEY=your-sendgrid-api-key
VITE_EMAIL_FROM=noreply@ajworld.ae
VITE_EMAIL_FROM_NAME="AJworld"

# SMS Service (Twilio)
VITE_TWILIO_ACCOUNT_SID=your-twilio-account-sid
VITE_TWILIO_AUTH_TOKEN=your-twilio-auth-token
VITE_TWILIO_PHONE_NUMBER=+971501234567

# WhatsApp Business API
VITE_WHATSAPP_API_KEY=your-whatsapp-api-key
VITE_WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id

# Live Chat (Tidio/Tawk.to)
VITE_LIVE_CHAT_KEY=your-live-chat-key

# SEO
VITE_SITE_TITLE="AJworld - تسوق إلكتروني في الإمارات"
VITE_SITE_KEYWORDS="تسوق اونلاين, دبي, ابوظبي, الامارات, AJworld"
VITE_SITE_AUTHOR="Khaled Mohammed Saleh Awad Aljaberi"

# Feature Flags
VITE_ENABLE_GUEST_CHECKOUT=true
VITE_ENABLE_WISHLIST=true
VITE_ENABLE_COMPARE=true
VITE_ENABLE_LOYALTY=true
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_LIVE_CHAT=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_GPS_TRACKING=true
VITE_ENABLE_MULTI_LANGUAGE=true
VITE_ENABLE_MULTI_CURRENCY=true

# Default Settings
VITE_DEFAULT_LANGUAGE=ar
VITE_DEFAULT_CURRENCY=AED
VITE_DEFAULT_COUNTRY=AE
VITE_DEFAULT_TIMEZONE=Asia/Dubai

# Shipping
VITE_FREE_SHIPPING_THRESHOLD=200
VITE_DEFAULT_SHIPPING_COST=15
VITE_EXPRESS_SHIPPING_COST=35

# Tax
VITE_TAX_RATE=5
VITE_TAX_INCLUDED=true

# Pagination
VITE_PRODUCTS_PER_PAGE=20
VITE_ORDERS_PER_PAGE=10
VITE_REVIEWS_PER_PAGE=5

# Cache
VITE_CACHE_DURATION=3600
VITE_ENABLE_OFFLINE_MODE=true

# Development
VITE_DEV_MODE=false
VITE_DEBUG_MODE=false
VITE_MOCK_API=false
